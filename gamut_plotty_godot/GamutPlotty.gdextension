[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://../target/debug/libgamut_plotty_ext.so"
linux.release.x86_64 =   "res://../target/release/libgamut_plotty_ext.so"
windows.debug.x86_64 =   "res://../target/debug/gamut_plotty_ext.dll"
windows.release.x86_64 = "res://../target/release/gamut_plotty_ext.dll"
macos.debug =            "res://../target/debug/libgamut_plotty_ext.dylib"
macos.release =          "res://../target/release/libgamut_plotty_ext.dylib"
macos.debug.arm64 =      "res://../target/debug/libgamut_plotty_ext.dylib"
macos.release.arm64 =    "res://../target/release/libgamut_plotty_ext.dylib"
